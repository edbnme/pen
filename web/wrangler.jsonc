{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pen",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true,
  },
  "assets": {
    "directory": ".",
  },
  "routes": [
    {
      "pattern": "pen.edbn.me",
      "custom_domain": true,
      "override_existing_origin": true,
      "override_existing_dns_record": true,
    },
  ],
  "compatibility_flags": ["nodejs_compat"],
}
